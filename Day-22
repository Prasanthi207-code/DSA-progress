1Given an array arr[], sorted in ascending order and an integer k. Return true if k is present in the array, otherwise, false.
Platform : GeeksForGeeks
SOURCE CODE : class Solution {
    public boolean binarySearch(int[] arr, int k) {
       int l=0;
       int h=arr.length-1;
       while(l<=h){
          int mid=l+(h-l)/2;
            
        if(arr[mid]==k)
        {
            return true;
            
        }
          else if(arr[mid]>k){
              h=mid-1;
          }
          else {
              l=mid+1;
          }
       }return false; 
    }
}
