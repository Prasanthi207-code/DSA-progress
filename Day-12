1.Given an array arr[], swap the kth element from the beginning with the kth element from the end.
Platform : GeeksForGeeks
SOURCE CODE : 
class Solution {
    public void swapKth(List<Integer> arr, int k) {
      int n=arr.size();
        if(k>n)return;
         int i=k-1;
         int j=n-k;
                   int temp=arr.get(i);
                   arr.set(i,arr.get(j));
                   arr.set(j,temp);
  
    }
}
