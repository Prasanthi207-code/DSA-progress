4.Given a number n, check if the number is perfect or not. A number is said to be perfect if sum of all its factors excluding the number itself is equal to the number.
Platform : GeeksForGeeks
SOURCE CODE :class Solution {
    static boolean isPerfect(int n) {int sum=1;
    if(n<=1)return false;
        for(int i=2;i*i<=n;i++){
        if(n%i==0){
           sum+=i;
       
        if(i!=n/i){sum+=n/i;
        } }}
         return sum==n;
    }
}
