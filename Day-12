2.Given an array arr of distinct elements, the task is to return an array of all elements except the two greatest elements in sorted order.
Platform : GeeksForGeeks
SOURCE CODE : class Solution {
    public long[] findElements(long arr[]) {
        Arrays.sort(arr); int n=arr.length;
        ArrayList<Long>l=new ArrayList<>();
        for(int i=0;i<n-2;i++){
            l.add(arr[i]);
        }
        long[] result=new long[l.size()];
        for(int i=0;i<l.size();i++){
          result[i]=l.get(i);
        }  
   return result; }
}
