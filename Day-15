3.You are given a circular array arr[] of integers, find the maximum possible sum of a non-empty subarray. In a circular array, the subarray can start at the end and wrap around to the beginning. Return the maximum non-empty subarray sum, considering both non-wrapping and wrapping cases.
Platform : GeeksForGeeks
SOURCE CODE :class Solution {
    public int maxCircularSum(int arr[]) {
       int sum=0;
       int max=arr[0];
       int tempmax=0;
       int tempmin=0;
       int min=arr[0];
       for(int i:arr){
          
              tempmax=Math.max(i,tempmax+i);
             max=Math.max(max,tempmax);
             
              tempmin=Math.min(i,tempmin+i);
             min=Math.min(min,tempmin);
      
             sum+=i;}
           if(max<=0){return max;}
           
           return Math.max(max,sum-min);
    
    }
}

