5.You are given an integer n. You need to convert all zeroes of n to 5.
Platform:GeeksForGeeks
SOURCE CODE: class Solution {
    int convertfive(int num) {
      if(num==0)return 5;
       int rev=0;   // Your code here
       while(num>0){
         int digit=num%10;
         if(digit==0){
             digit=5;
         }
         rev=rev*10+digit;
    
         num=num/10;
       }
       int ans=0;
       while(rev>0){
           ans=ans*10+rev%10;
           rev=rev/10;
       }
    return ans;    } 
}
