1. Given an array arr[] . Rotate the array to the left (counter-clockwise direction) by d steps, where d is a positive integer. Do the mentioned change in the array in place.
platform : GeeksForGeeks 
SOURCECODE : class Solution {
    static void rotateArr(int arr[], int d) {
     d=d%arr.length;
       int temp[]=new int[d];
       for(int i=0;i<d;i++){
           temp[i]=arr[i];
       }
       for(int i=d;i<arr.length;i++){
           arr[i-d]=arr[i];
       }
       for(int i=0;i<d;i++){
           arr[arr.length-d+i]=temp[i];
       }
    }
}
