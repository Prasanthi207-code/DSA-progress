5.Given an array of integers arr, return true if the number of occurrences of each value in the array is unique or false otherwise.
Platform : Leetcode
SOURCECODE :class Solution {
    public boolean uniqueOccurrences(int[] arr) {
     HashMap<Integer,Integer>l=new HashMap<>();
      for(int i:arr){
        l.put(i,l.getOrDefault(i,0)+1);
      }  
      HashSet<Integer>s=new HashSet<>();
      for(int i:l.values()){
        if(s.contains(i)){
            return false;
        }s.add(i);
      }return true;
    }
}
