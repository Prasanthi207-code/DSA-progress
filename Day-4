1.You are given the head of a Singly Linked List and a value x, insert that value x at the end of the LinkedList and return the head of the modified Linked List.
Platform : Geeks For Geeks
SOURCE CODE : /*
class Node{
    int data;
    Node next;

    Node(int x){
        data = x;
        next = null;
    }
}
*/
class Solution {
    public Node insertAtEnd(Node head, int x) {
        Node newnode=new Node(x);
        if(head==null) 
            head=newnode;
 
        else{
            Node temp=head;
            while(temp.next!=null){
                temp=temp.next;
            }     temp.next=newnode;
        }
  return  head;  }
}
