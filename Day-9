6.Given the head of a singly linked list, reverse the list, and return the reversed list.
Platform:Leetcode
SOURCE CODE:class Solution {
    public ListNode reverseList(ListNode head) {
        ListNode temp=head;ListNode prev=null;ListNode next=null;
        if(head==null){return head; }
        while(temp!=null){
             next=temp.next;
             temp.next=prev;
             prev=temp;
             temp=next;
        }head=prev;
   return head; }
}
