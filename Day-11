4.Given an array arr of positive integers, return the minimum possible product of any k elements from the array. Return the result modulo 1e9 + 7.
Platform : GeeksForGeeks
SOURCE CODE : class Solution {

    int minProduct(int arr[], int k) {
      Arrays.sort(arr);
      k=Math.min(k,arr.length);
      long product=1;
      long mod=1000000007;
      for(int i=0;i<k;i++){
          product=(product*arr[i])%mod;
      }
        return (int)product;
    }
}

