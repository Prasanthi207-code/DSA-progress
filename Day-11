11.Given two sorted arrays a[] and b[], find and return the median of the combined array after merging them into a single sorted array.
Platform : GeeksForGeeks
SOURCE CODE : class Solution {
    public double medianOf2(int a[], int b[]) {
    
        int n = a.length+b.length;;

        int i = 0, j = 0;
        int count = 0;
        int m1 = -1, m2 = -1;

        while (count <= n/2) {
            m1 = m2;

            if (i == a.length) {
                m2 = b[j++];
            } else if (j == b.length) {
                m2 = a[i++];
            } else if (a[i] <= b[j]) {
                m2 = a[i++];
            } else {
                m2 = b[j++];
            }

            count++;
        }
      if(n%2==0)
        return (m1 + m2) / 2.0;
        else 
        return m2;
    }
} 
Link : https://www.geeksforgeeks.org/problems/median-of-2-sorted-arrays-of-different-sizes/1
12.Given two sorted arrays a[] and b[] of equal size, find and return the median of the combined array after merging them into a single sorted array.
Platform : GeeksForGeeks
SOURCE CODE : class Solution {
    double medianOf2(int[] a, int[] b) {
        int n = a.length;

        int i = 0, j = 0;
        int count = 0;
        int m1 = -1, m2 = -1;

        while (count <= n) {
            m1 = m2;

            if (i == n) {
                m2 = b[j++];
            } else if (j == n) {
                m2 = a[i++];
            } else if (a[i] <= b[j]) {
                m2 = a[i++];
            } else {
                m2 = b[j++];
            }

            count++;
        }

        return (m1 + m2) / 2.0;
    }
}
